<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>

<VBox spacing="10.0" xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.project.artconnect.ui.ArtistController">
    <padding><Insets bottom="10.0" left="10.0" right="10.0" top="10.0"/></padding>

    <!-- Barre recherche -->
    <HBox spacing="10.0" alignment="CENTER_LEFT">
        <TextField fx:id="searchField" promptText="Search artists..." HBox.hgrow="ALWAYS"/>
        <ComboBox fx:id="disciplineFilter" promptText="Filter by Discipline"/>
        <Button text="Search" onAction="#handleSearch"/>
        <Button text="Reset"  onAction="#handleReset"/>
    </HBox>

    <!-- Tableau -->
    <TableView fx:id="artistTable" VBox.vgrow="ALWAYS">
        <columns>
            <TableColumn fx:id="nameColumn"  text="Name"       prefWidth="200"/>
            <TableColumn fx:id="cityColumn"  text="City"       prefWidth="130"/>
            <TableColumn fx:id="emailColumn" text="Email"      prefWidth="200"/>
            <TableColumn fx:id="yearColumn"  text="Birth Year" prefWidth="90"/>
        </columns>
    </TableView>

    <!-- Boutons CRUD — minHeight force leur visibilité -->
    <HBox spacing="10.0" alignment="CENTER_RIGHT" minHeight="40.0">
        <Button text="Add Artist"    onAction="#handleAdd"
                style="-fx-background-color:#4CAF50;-fx-text-fill:white;-fx-font-weight:bold;-fx-padding:8 16;"/>
        <Button text="Edit Artist"   onAction="#handleEdit"
                style="-fx-background-color:#2196F3;-fx-text-fill:white;-fx-font-weight:bold;-fx-padding:8 16;"/>
        <Button text="Delete Artist" onAction="#handleDelete"
                style="-fx-background-color:#f44336;-fx-text-fill:white;-fx-font-weight:bold;-fx-padding:8 16;"/>
    </HBox>
</VBox>
