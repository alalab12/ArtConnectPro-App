<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>

<VBox spacing="8" xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.project.artconnect.ui.WorkshopController">
  <padding><Insets bottom="10" left="10" right="10" top="10"/></padding>

  <Label text="Workshops" style="-fx-font-size:16;-fx-font-weight:bold;"/>

  <HBox spacing="10" VBox.vgrow="ALWAYS">

    <TableView fx:id="workshopTable" HBox.hgrow="ALWAYS" onMouseClicked="#handleTableClick">
      <columns>
        <TableColumn fx:id="titleColumn"       text="Title"       prefWidth="180"/>
        <TableColumn fx:id="instructorColumn"  text="Instructor"  prefWidth="130"/>
        <TableColumn fx:id="dateColumn"        text="Date"        prefWidth="130"/>
        <TableColumn fx:id="locationColumn"    text="Location"    prefWidth="130"/>
        <TableColumn fx:id="levelColumn"       text="Level"       prefWidth="80"/>
        <TableColumn fx:id="priceColumn"       text="Price (€)"   prefWidth="75"/>
        <TableColumn fx:id="spotsColumn"       text="Max spots"   prefWidth="75"/>
      </columns>
    </TableView>

    <!-- Panneau détail -->
    <VBox spacing="8" prefWidth="280" minWidth="260"
          style="-fx-background-color:#f5f5f5;-fx-border-color:#ddd;-fx-border-radius:6;-fx-background-radius:6;-fx-padding:12;">
      <Label text="Workshop Details" style="-fx-font-size:15;-fx-font-weight:bold;-fx-text-fill:#333;"/>
      <Separator/>
      <Label fx:id="detailTitle"       text="—" style="-fx-font-weight:bold;-fx-font-size:13;"/>
      <Label fx:id="detailInstructor"  text="Instructor: —"  wrapText="true"/>
      <Label fx:id="detailDate"        text="Date: —"/>
      <Label fx:id="detailDuration"    text="Duration: —"/>
      <Label fx:id="detailLocation"    text="Location: —"    wrapText="true"/>
      <Label fx:id="detailLevel"       text="Level: —"/>
      <Label fx:id="detailPrice"       text="Price: —"/>
      <Label fx:id="detailSpots"       text="Max participants: —"/>
      <Separator/>
      <Label text="Description" style="-fx-font-weight:bold;"/>
      <Label fx:id="detailDesc" text="—" wrapText="true" style="-fx-text-fill:#555;"/>
    </VBox>
  </HBox>
</VBox>
