<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>

<VBox spacing="8" xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.project.artconnect.ui.ArtworkController">
  <padding><Insets bottom="10" left="10" right="10" top="10"/></padding>

  
  <HBox spacing="8" alignment="CENTER_LEFT">
    <ComboBox fx:id="typeFilter"   promptText="Filter by Type"   onAction="#handleFilter"/>
    <ComboBox fx:id="statusFilter" promptText="Filter by Status" onAction="#handleFilter"/>
    <Button text="Reset" onAction="#handleReset"/>
  </HBox>

  <HBox spacing="10" VBox.vgrow="ALWAYS">

    
    <TableView fx:id="artworkTable" HBox.hgrow="ALWAYS" onMouseClicked="#handleTableClick">
      <columns>
        <TableColumn fx:id="titleColumn"  text="Title"       prefWidth="180"/>
        <TableColumn fx:id="artistColumn" text="Artist"      prefWidth="130"/>
        <TableColumn fx:id="typeColumn"   text="Type"        prefWidth="100"/>
        <TableColumn fx:id="mediumColumn" text="Medium"      prefWidth="110"/>
        <TableColumn fx:id="yearColumn"   text="Year"        prefWidth="55"/>
        <TableColumn fx:id="priceColumn"  text="Price (€)"   prefWidth="80"/>
        <TableColumn fx:id="statusColumn" text="Status"      prefWidth="90"/>
      </columns>
    </TableView>

    
    <VBox fx:id="detailPane" spacing="8" prefWidth="270" minWidth="250"
          style="-fx-background-color:#f5f5f5;-fx-border-color:#ddd;-fx-border-radius:6;-fx-background-radius:6;-fx-padding:12;">
      <Label text="Artwork Details" style="-fx-font-size:15;-fx-font-weight:bold;-fx-text-fill:#333;"/>
      <Separator/>
      <Label fx:id="detailTitle"      text="—" style="-fx-font-weight:bold;-fx-font-size:13;"/>
      <Label fx:id="detailArtist"     text="Artist: —"      wrapText="true"/>
      <Label fx:id="detailType"       text="Type: —"/>
      <Label fx:id="detailMedium"     text="Medium: —"      wrapText="true"/>
      <Label fx:id="detailDimensions" text="Dimensions: —"  wrapText="true"/>
      <Label fx:id="detailYear"       text="Year: —"/>
      <Label fx:id="detailPrice"      text="Price: —"/>
      <Label fx:id="detailStatus"     text="Status: —"/>
      <Separator/>
      <Label text="Description" style="-fx-font-weight:bold;"/>
      <Label fx:id="detailDesc" text="—" wrapText="true" style="-fx-text-fill:#555;"/>
      <Separator/>
      <Label text="Exhibitions featuring this work" style="-fx-font-weight:bold;"/>
      <ListView fx:id="detailExhibitions" prefHeight="100"/>
    </VBox>
  </HBox>

  <HBox spacing="10" alignment="CENTER_RIGHT" minHeight="40">
    <Button text="Add Artwork"    onAction="#handleAdd"
            style="-fx-background-color:#4CAF50;-fx-text-fill:white;-fx-font-weight:bold;-fx-padding:8 16;"/>
    <Button text="Edit Artwork"   onAction="#handleEdit"
            style="-fx-background-color:#9e5a5a;-fx-text-fill:white;-fx-font-weight:bold;-fx-padding:8 16;"/>
    <Button text="Delete Artwork" onAction="#handleDelete"
            style="-fx-background-color:#7c2d2d;-fx-text-fill:white;-fx-font-weight:bold;-fx-padding:8 16;"/>
  </HBox>
</VBox>
