<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>

<VBox spacing="8" xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.project.artconnect.ui.CommunityController">
  <padding><Insets bottom="10" left="10" right="10" top="10"/></padding>

  <Label text="Community Members" style="-fx-font-size:16;-fx-font-weight:bold;"/>

  <HBox spacing="10" VBox.vgrow="ALWAYS">

    <TableView fx:id="memberTable" HBox.hgrow="ALWAYS" onMouseClicked="#handleTableClick">
      <columns>
        <TableColumn fx:id="nameColumn"       text="Name"       prefWidth="160"/>
        <TableColumn fx:id="emailColumn"      text="Email"      prefWidth="180"/>
        <TableColumn fx:id="cityColumn"       text="City"       prefWidth="100"/>
        <TableColumn fx:id="membershipColumn" text="Membership" prefWidth="90"/>
        <TableColumn fx:id="yearColumn"       text="Born"       prefWidth="60"/>
      </columns>
    </TableView>

    
    <VBox fx:id="detailPane" spacing="8" prefWidth="290" minWidth="270"
          style="-fx-background-color:#f5f5f5;-fx-border-color:#ddd;-fx-border-radius:6;-fx-background-radius:6;-fx-padding:12;">
      <Label text="Member Details" style="-fx-font-size:15;-fx-font-weight:bold;-fx-text-fill:#333;"/>
      <Separator/>
      <Label fx:id="detailName"       text="—" style="-fx-font-weight:bold;-fx-font-size:13;"/>
      <Label fx:id="detailEmail"      text="Email: —"      wrapText="true"/>
      <Label fx:id="detailCity"       text="City: —"/>
      <Label fx:id="detailPhone"      text="Phone: —"/>
      <Label fx:id="detailYear"       text="Born: —"/>
      <Label fx:id="detailMembership" text="Membership: —"/>
      <Separator/>
      <Label text="Reviews written" style="-fx-font-weight:bold;"/>
      <ListView fx:id="reviewList" VBox.vgrow="ALWAYS" prefHeight="180"/>
    </VBox>
  </HBox>

  <HBox spacing="10" alignment="CENTER_RIGHT" minHeight="40">
    <Button text="Add Member"    onAction="#handleAdd"
            style="-fx-background-color:#4CAF50;-fx-text-fill:white;-fx-font-weight:bold;-fx-padding:8 16;"/>
    <Button text="Edit Member"   onAction="#handleEdit"
            style="-fx-background-color:#9e5a5a;-fx-text-fill:white;-fx-font-weight:bold;-fx-padding:8 16;"/>
    <Button text="Delete Member" onAction="#handleDelete"
            style="-fx-background-color:#7c2d2d;-fx-text-fill:white;-fx-font-weight:bold;-fx-padding:8 16;"/>
  </HBox>
</VBox>
