<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>

<VBox spacing="10.0" xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.project.artconnect.ui.ArtworkController">
    <padding><Insets bottom="10.0" left="10.0" right="10.0" top="10.0"/></padding>

    <!-- Tableau -->
    <TableView fx:id="artworkTable" VBox.vgrow="ALWAYS">
        <columns>
            <TableColumn fx:id="titleColumn"  text="Title"  prefWidth="200"/>
            <TableColumn fx:id="artistColumn" text="Artist" prefWidth="150"/>
            <TableColumn fx:id="typeColumn"   text="Type"   prefWidth="100"/>
            <TableColumn fx:id="priceColumn"  text="Price"  prefWidth="100"/>
            <TableColumn fx:id="statusColumn" text="Status" prefWidth="150"/>
        </columns>
    </TableView>

    <!-- Boutons CRUD -->
    <HBox spacing="10.0" alignment="CENTER_RIGHT" minHeight="40.0">
        <Button text="Add Artwork"    onAction="#handleAdd"
                style="-fx-background-color:#4CAF50;-fx-text-fill:white;-fx-font-weight:bold;-fx-padding:8 16;"/>
        <Button text="Edit Artwork"   onAction="#handleEdit"
                style="-fx-background-color:#2196F3;-fx-text-fill:white;-fx-font-weight:bold;-fx-padding:8 16;"/>
        <Button text="Delete Artwork" onAction="#handleDelete"
                style="-fx-background-color:#f44336;-fx-text-fill:white;-fx-font-weight:bold;-fx-padding:8 16;"/>
    </HBox>
</VBox>
