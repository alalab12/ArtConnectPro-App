<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>

<VBox spacing="10.0" xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.project.artconnect.ui.CommunityController">
    <padding><Insets bottom="10.0" left="10.0" right="10.0" top="10.0"/></padding>

    <!-- Tableau des membres -->
    <TableView fx:id="memberTable" VBox.vgrow="ALWAYS">
        <columns>
            <TableColumn fx:id="nameColumn"       text="Name"            prefWidth="180"/>
            <TableColumn fx:id="emailColumn"      text="Email"           prefWidth="200"/>
            <TableColumn fx:id="cityColumn"       text="City"            prefWidth="120"/>
            <TableColumn fx:id="membershipColumn" text="Membership"      prefWidth="100"/>
            <TableColumn fx:id="yearColumn"       text="Birth Year"      prefWidth="90"/>
        </columns>
    </TableView>

    <!-- Boutons CRUD -->
    <HBox spacing="10.0" alignment="CENTER_RIGHT" minHeight="40.0">
        <Button text="Add Member"    onAction="#handleAdd"
                style="-fx-background-color:#4CAF50;-fx-text-fill:white;-fx-font-weight:bold;-fx-padding:8 16;"/>
        <Button text="Edit Member"   onAction="#handleEdit"
                style="-fx-background-color:#2196F3;-fx-text-fill:white;-fx-font-weight:bold;-fx-padding:8 16;"/>
        <Button text="Delete Member" onAction="#handleDelete"
                style="-fx-background-color:#f44336;-fx-text-fill:white;-fx-font-weight:bold;-fx-padding:8 16;"/>
    </HBox>
</VBox>
